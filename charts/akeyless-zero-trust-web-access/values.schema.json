{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://akeyless.io/helm-charts/akeyless-zero-trust-web-access/values.schema.json",
  "title": "Akeyless Zero Trust Web Access Helm chart values",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "image": {
      "type": "object",
      "additionalProperties": true,
      "title": "Global image and registry pull settings",
      "properties": {
        "imagePullSecrets": {
          "type": "array",
          "description": "List of { name: secretName } for every pod. Merged with per-workload imagePullSecrets and, when set, the chart-generated docker secret (deduplicated).",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "name": { "type": "string" }
            },
            "required": ["name"]
          }
        },
        "dockerRepositoryCreds": {
          "type": ["string", "null"],
          "deprecated": true,
          "description": "Deprecated. Base64 dockerconfig used only to create the pre-install pull secret. Prefer a kubernetes.io/dockerconfigjson secret you create and set image.imagePullSecrets; this field will be removed in a future version."
        }
      }
    },
    "dispatcher": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "initContainer": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "imagePullSecrets": {
              "type": "array",
              "description": "Merged on the dispatcher pod with image.imagePullSecrets and dispatcher.image.imagePullSecrets; deduplicated at pod spec.",
              "items": {
                "type": "object",
                "additionalProperties": true,
                "properties": { "name": { "type": "string" } },
                "required": ["name"]
              }
            }
          }
        },
        "image": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "imagePullSecrets": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": true,
                "properties": { "name": { "type": "string" } },
                "required": ["name"]
              }
            }
          }
        },
        "config": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "cloudIdentity": {
              "type": "object",
              "additionalProperties": true,
              "description": "Cloud identity override. Forces the dispatcher to authenticate via the configured cloud identity instead of probing IMDS. Use this on clusters where the dispatcher pod cannot reach 169.254.169.254 (e.g. EKS with IMDSv2 hop-limit=1).",
              "properties": {
                "type": {
                  "type": "string",
                  "enum": ["", "aws_iam", "azure_ad", "gcp"],
                  "description": "Set to short-circuit IMDS classification and authenticate via the configured cloud identity. Empty string (default) preserves IMDS auto-detection."
                }
              }
            }
          }
        }
      }
    },
    "webWorker": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "initContainer": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "imagePullSecrets": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": true,
                "properties": { "name": { "type": "string" } },
                "required": ["name"]
              }
            }
          }
        },
        "image": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "imagePullSecrets": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": true,
                "properties": { "name": { "type": "string" } },
                "required": ["name"]
              }
            }
          }
        }
      }
    },
    "webProxy": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "initContainer": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "imagePullSecrets": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": true,
                "properties": { "name": { "type": "string" } },
                "required": ["name"]
              }
            }
          }
        },
        "image": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "imagePullSecrets": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": true,
                "properties": { "name": { "type": "string" } },
                "required": ["name"]
              }
            }
          }
        },
        "service": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "type": { "type": "string" },
            "port": { "type": "integer" }
          }
        },
        "ingress": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "enabled": { "type": "boolean" },
            "parentGateway": { "type": "string" },
            "sectionName": { "type": "string" }
          }
        }
      }
    },
    "validator": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "image": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "imagePullSecrets": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": true,
                "properties": { "name": { "type": "string" } },
                "required": ["name"]
              }
            }
          }
        }
      }
    }
  }
}
