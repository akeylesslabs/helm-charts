{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "properties": {
    "cache" : {
      "properties": {
        "tls": {
          "properties": {
            "autoGenerated" : { "type": "boolean" },
            "existingSecretName": { "type": "string" }
          }
        }
      }
    },
    "cachingConf" : {
      "properties": {
        "clusterCache": {
          "properties": {
            "enabled" : { "type": "boolean" },
            "encryptionKeyExistingSecret": { "oneOf": [{ "type": "string"}, { "type": "null" }]}
          },
          "allOf": [
            {
              "if": {
                "properties": {
                  "enabled": { "const": true }
                }
              },
              "then": {
                "properties": {
                  "encryptionKeyExistingSecret": { "type": "string", "pattern": "^[a-zA-Z0-9-]+$" }
                }
              }
            }
          ]
        }
      }
    },
    "akeylessUserAuth": {
      "description": "Akeyless authentication configuration",
      "properties": {
        "blockedAccessIds": {
          "oneOf": [
            { "type": "null" },
            {
              "type": "array",
              "items": { "type": "string" }
            }
          ],
          "uniqueItems": true,
          "default": null
        },
        "allowedAccessPermissions": {
          "type": "array",
          "description": "List of allowed access permissions",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "access_id": { "type": "string" },
              "sub_claims": { "type": "object" },
              "case_sensitive": { "type": "boolean" },
              "permissions": {
                "type": "array",
                "items": { "type": "string" }
              }
            },
            "required": ["name", "access_id"]
          }
        }
      },
      "type": "object"
    },
    "gatewayAPI": {
      "type": "object",
      "description": "Kubernetes Gateway API support (ASM-16238)",
      "properties": {
        "enabled": { "type": "boolean" },
        "gateway": {
          "type": "object",
          "properties": {
            "create": { "type": "boolean" },
            "name": { "type": "string" },
            "gatewayClassName": { "type": "string" },
            "annotations": { "type": "object" },
            "labels": { "type": "object" },
            "listeners": { "type": "array" },
            "allowedRoutes": { "type": "object" },
            "tls": {
              "type": "object",
              "properties": {
                "enabled": { "type": "boolean" },
                "mode": { "type": "string", "enum": ["Terminate", "Passthrough"] },
                "certificateRefs": { "type": "array" }
              }
            }
          }
        },
        "parentRefs": { "type": "array" },
        "httpRoutes": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "hostname": { "type": "string" },
              "servicePort": { "type": "string" },
              "path": { "type": "string" },
              "pathType": { "type": "string", "enum": ["Exact", "PathPrefix", "RegularExpression"] }
            },
            "required": ["servicePort"]
          }
        },
        "httpRoutePath": { "type": "string" },
        "httpRoutePathType": { "type": "string", "enum": ["Exact", "PathPrefix", "RegularExpression"] },
        "tlsRoutes": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "hostname": { "type": "string" },
              "servicePort": { "type": "string" }
            },
            "required": ["servicePort"]
          }
        },
        "tcpRoutes": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "servicePort": { "type": "string" }
            },
            "required": ["name", "servicePort"]
          }
        }
      }
    }
  },
  "title": "Values",
  "type": "object"
}